---
interface Props {
  title?: string;
}
const { title = 'blog-cms' } = Astro.props;
const user = Astro.locals.user;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <!-- ホーム画面追加対応（フル PWA はやらない。standalone も Access ログイン遷移が壊れるため入れない） -->
    <meta name="theme-color" content="#1e1e1e" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="日記" />
    <title>{title}</title>
  </head>
  <body>
    <header class="topbar">
      <div class="left">
        <a href="/" class="brand">blog-cms</a>
        <nav class="nav">
          <a href="/">✏️ 新規日記</a>
          <a href="/posts">一覧</a>
        </nav>
      </div>
      {user && <span class="user">{user.email}</span>}
    </header>
    <main>
      <slot />
    </main>
    <style is:global>
      :root { color-scheme: light dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, sans-serif;
        line-height: 1.6;
      }
      .topbar {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.75rem 1.25rem; border-bottom: 1px solid #8884;
      }
      .left { display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; }
      .brand { font-weight: 700; text-decoration: none; color: inherit; }
      .nav { display: inline-flex; gap: 0.9rem; font-size: 0.85rem; }
      .nav a { text-decoration: none; }
      .user { font-size: 0.8rem; opacity: 0.6; }
      main { max-width: 820px; margin: 0 auto; padding: 1.5rem 1.25rem 4rem; }
      a { color: #3b82f6; }
      button, input, textarea, select {
        font: inherit; padding: 0.5rem 0.7rem; border-radius: 8px;
        border: 1px solid #8886; background: transparent; color: inherit;
      }
      button { cursor: pointer; background: #3b82f6; color: #fff; border: none; }
      button.secondary { background: transparent; color: inherit; border: 1px solid #8886; }
      button:disabled { opacity: 0.5; cursor: default; }
      label { display: block; margin: 1rem 0 0.3rem; font-weight: 600; font-size: 0.9rem; }
      /* iOS: フォーカス時の自動ズームは font-size < 16px の入力で発動する */
      input, textarea, select { width: 100%; font-size: 16px; }
      textarea { min-height: 360px; font-family: ui-monospace, monospace; }

      /* Toast UI: 挿入直後の実寸大画像がエディタ幅を突き破るのを防ぐ */
      .toastui-editor-contents img { max-width: 100%; height: auto; }
      /* Toast UI の既定 13px は小さい。他の入力欄と同じ 16px に（iOS の自動ズーム回避条件とも一致） */
      .toastui-editor-contents { font-size: 16px; }
      .toastui-editor-defaultUI { max-width: 100%; }

      @media (max-width: 640px) {
        main { padding: 0.75rem; }
        button, .btn { min-height: 44px; } /* Apple HIG のタップターゲット */
      }
    </style>
  </body>
</html>
