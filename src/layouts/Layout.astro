---
interface Props {
  title?: string;
}
const { title = 'blog-cms' } = Astro.props;
const user = Astro.locals.user;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title}</title>
  </head>
  <body>
    <header class="topbar">
      <a href="/" class="brand">blog-cms</a>
      {user && <span class="user">{user.email}</span>}
    </header>
    <main>
      <slot />
    </main>
    <style is:global>
      :root { color-scheme: light dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, sans-serif;
        line-height: 1.6;
      }
      .topbar {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.75rem 1.25rem; border-bottom: 1px solid #8884;
      }
      .brand { font-weight: 700; text-decoration: none; color: inherit; }
      .user { font-size: 0.8rem; opacity: 0.6; }
      main { max-width: 820px; margin: 0 auto; padding: 1.5rem 1.25rem 4rem; }
      a { color: #3b82f6; }
      button, input, textarea, select {
        font: inherit; padding: 0.5rem 0.7rem; border-radius: 8px;
        border: 1px solid #8886; background: transparent; color: inherit;
      }
      button { cursor: pointer; background: #3b82f6; color: #fff; border: none; }
      button.secondary { background: transparent; color: inherit; border: 1px solid #8886; }
      button:disabled { opacity: 0.5; cursor: default; }
      label { display: block; margin: 1rem 0 0.3rem; font-weight: 600; font-size: 0.9rem; }
      input, textarea, select { width: 100%; }
      textarea { min-height: 360px; font-family: ui-monospace, monospace; }
    </style>
  </body>
</html>
